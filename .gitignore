
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# ESP-IDF build artifacts
build/
sdkconfig
sdkconfig.old
managed_components/
dependencies.lock

# Host build artifacts
build-host/
build-oracle/

# Release artifacts (multi-board OTA + USB-flash bundles produced by
# scripts/build-release.sh). Tagged releases live on GitHub releases,
# not in the repo.
release/
build-release/

# Editor scratch
.vscode/
.idea/
*.swp
*.swo

# Python bytecode (e.g. from running scripts/*.py during local dev)
__pycache__/
*.pyc

# Per-developer Wi-Fi credentials — checked-in template is
# main/wifi_credentials.example.h; the active file is gitignored.
main/wifi_credentials.h

# Third-party reference materials (Brother SDM PDF, OSS clones, installers).
# Kept strictly local: 300+ MB, embedded .git repos, and mixed licenses
# (incl. GPL) that must not be redistributed by this project.
refs/

# Upstream source archives (Bootstrap Icons zip etc.). The relevant
# files have already been extracted into the components that need
# them; the originals are kept locally for re-extract / version bumps
# but not redistributed.
external/
